<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- Projecte agregador (parent) — no conté codi propi -->
    <groupId>edu.uoc.b2</groupId>
    <artifactId>java-b2-exercicis</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <name>Java B2 — Exercicis</name>
    <description>Exercicis pràctics del mòdul Java B2</description>

    <!-- Mòduls (un per tema) -->
    <modules>
        <module>tema1-poo</module>
        <module>tema3-sql</module>
        <module>tema4-jdbc</module>
        <module>tema5-mongodb</module>
        <module>tema6-excepcions</module>
    </modules>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Versions de dependències (centralitzades aquí) -->
        <junit.version>5.10.1</junit.version>
        <assertj.version>3.25.1</assertj.version>
        <mockito.version>5.8.0</mockito.version>
        <mysql.version>8.3.0</mysql.version>
        <hikari.version>5.1.0</hikari.version>
        <mongodb.version>5.0.0</mongodb.version>
        <testcontainers.version>1.19.5</testcontainers.version>
    </properties>

    <!-- Dependències heretades per TOTS els mòduls fills -->
    <dependencyManagement>
        <dependencies>
            <!-- JUnit 5 BOM — gestiona totes les versions del framework -->
            <dependency>
                <groupId>org.junit</groupId>
                <artifactId>junit-bom</artifactId>
                <version>${junit.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- JUnit 5 Jupiter — disponible a tots els mòduls -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- AssertJ — assercions fluents i llegibles -->
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>${assertj.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- Mockito — mocks per als tests -->
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <version>${mockito.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Compilador Java 21 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.12.1</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <encoding>UTF-8</encoding>
                    <!-- Habilitar preview features de Java 21 si cal -->
                    <!-- <compilerArgs><arg>--enable-preview</arg></compilerArgs> -->
                </configuration>
            </plugin>

            <!-- Surefire — execució de tests JUnit 5 (requereix v3+) -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.3</version>
                <configuration>
                    <!-- Genera informes XML per al CI/CD -->
                    <reportFormat>xml</reportFormat>
                    <!-- Mostra els tests que fallen -->
                    <useFile>false</useFile>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
